# =============================================================================
# Warehouse — production environment template
# =============================================================================
# On the VPS:
#   cp .env.production.template .env.production
#   nano .env.production   # fill secrets; URL-encode special chars in DATABASE_URL
#   chmod 600 .env.production
#
# Docker Compose expands ${DATABASE_URL} when you run:
#   docker compose --env-file .env.production ...
# (see deploy.sh). For ad-hoc commands, symlink: ln -sf .env.production .env
#
# PostgreSQL is only reachable on the internal Docker network (not published).
# CloudPanel reverse proxy should target http://127.0.0.1:3001
# =============================================================================

# --- PostgreSQL (used by the `db` service in docker-compose) -----------------
# The official image creates this user as a superuser for the instance.
# Keep the database port unpublished; only the `app` container joins the network.
# Password: at least 20 random bytes; avoid quotes/newlines in POSTGRES_PASSWORD.
#   openssl rand -base64 24
POSTGRES_USER=warehouse_app
POSTGRES_PASSWORD=REPLACE_WITH_OPENSSL_RAND_BASE64_24
POSTGRES_DB=warehouse

# --- Prisma / Next.js --------------------------------------------------------
# Host `db` is the Docker Compose service name (TLS not required on the bridge).
# If the password contains @ : / ? # [ ] encode them (RFC 3986) in the URL.
DATABASE_URL="postgresql://warehouse_app:REPLACE_WITH_OPENSSL_RAND_BASE64_24@db:5432/warehouse?schema=public&sslmode=disable&connection_limit=10&pool_timeout=20"

# Public origin as seen in the browser (CloudPanel HTTPS domain).
NEXT_PUBLIC_APP_URL=https://warehouse.example.com

# Optional: rotate periodically; use if you add signed tokens or cron webhooks.
# AUTH_SECRET=$(openssl rand -hex 32)
# CRON_SECRET=$(openssl rand -hex 32)
